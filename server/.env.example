# JWT access token из личного кабинета WATA (merchant.wata.pro)
WATA_DG_TOKEN=your_jwt_access_token_here

# Порт сервера
PORT=3000

# Минимальная маржа (0.05 = 5%)
MARGIN=0.05

# Комиссия эквайринга WATA (0.085 = 8.5%)
COMMISSION=0.085

# Разрешённые домены для CORS (через запятую)
ALLOWED_ORIGINS=https://heystore.net,https://www.heystore.net
