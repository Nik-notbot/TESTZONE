# Основной терминал (TopUp + Vouchers)
WATA_DG_TOKEN=your_main_jwt_token

# Терминал для Telegram Stars
WATA_STARS_TOKEN=your_stars_jwt_token

# Терминал для Steam
WATA_STEAM_TOKEN=your_steam_jwt_token

# Порт сервера
PORT=3000

# Минимальная маржа (0.05 = 5%)
MARGIN=0.05

# Комиссия эквайринга WATA (0.085 = 8.5%)
COMMISSION=0.085

# Разрешённые домены для CORS (через запятую)
ALLOWED_ORIGINS=*
